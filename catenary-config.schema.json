{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Catenary Configuration",
  "type": "object",
  "properties": {
    "server": {
      "type": "object",
      "description": "Server definitions keyed by language ID (e.g., 'rust', 'python').",
      "additionalProperties": {
        "$ref": "#/definitions/server_config"
      }
    },
    "tools": {
      "type": "object",
      "description": "Per-tool configuration.",
      "properties": {
        "grep": {
          "type": "object",
          "description": "Grep tool configuration.",
          "properties": {
            "budget": {
              "type": "integer",
              "description": "Output budget in characters. Minimum: 2000.",
              "default": 4000,
              "minimum": 2000
            }
          }
        },
        "glob": {
          "type": "object",
          "description": "Glob tool configuration.",
          "properties": {
            "budget": {
              "type": "integer",
              "description": "Output budget in characters. Minimum: 1000.",
              "default": 2000,
              "minimum": 1000
            },
            "maps_threshold": {
              "type": "integer",
              "description": "Minimum line count for defensive maps.",
              "default": 200,
              "minimum": 1
            },
            "maps_deny": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Glob patterns excluded from defensive maps.",
              "default": []
            }
          }
        }
      }
    }
  },
  "definitions": {
    "server_config": {
      "type": "object",
      "required": ["command"],
      "properties": {
        "command": {
          "type": "string",
          "description": "The command to execute (e.g., 'rust-analyzer', 'pyright-langserver')."
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Arguments to pass to the command.",
          "default": []
        },
        "initialization_options": {
          "type": "object",
          "description": "Initialization options to pass to the LSP server during the 'initialize' request.",
          "additionalProperties": true
        },
        "settings": {
          "type": "object",
          "description": "Server-specific settings returned in workspace/configuration responses. The TOML nesting mirrors the JSON the server expects. Catenary matches the 'section' path from configuration requests and returns the subtree.",
          "additionalProperties": true
        }
      }
    }
  }
}
