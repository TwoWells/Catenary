{
  "hooks": {
    "AfterTool": [
      {
        "matcher": "read_file|write_file|replace",
        "hooks": [
          {
            "name": "catenary-notify",
            "type": "command",
            "command": "catenary hook post-tool --format=gemini"
          }
        ]
      }
    ]
  }
}
